{
  "name": "xrelay",
  "version": "0.1.2",
  "description": "Vercel Edge Function proxy with free proxy pool and fallback",
  "main": "api/index.ts",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "dev:api": "node server.js",
    "dev:standalone": "bun run src/standalone.ts",
    "build:frontend": "vite build --config config/vite.config.ts",
    "build:api": "tsc --project config/tsconfig.json --outDir dist",
    "build": "npm run build:frontend && npm run build:api",
    "build:binary": "bash scripts/build-binary.sh",
    "build:binary:linux-x64": "bash scripts/build-binary.sh --os linux --arch x64",
    "build:binary:linux-arm64": "bash scripts/build-binary.sh --os linux --arch arm64",
    "build:binary:macos-x64": "bash scripts/build-binary.sh --os macos --arch x64",
    "build:binary:macos-arm64": "bash scripts/build-binary.sh --os macos --arch arm64",
    "build:binary:windows-x64": "bash scripts/build-binary.sh --os windows --arch x64",
    "build:all": "npm run build:binary:linux-x64 && npm run build:binary:linux-arm64 && npm run build:binary:macos-x64 && npm run build:binary:macos-arm64 && npm run build:binary:windows-x64",
    "preview": "vite preview --config config/vite.config.ts",
    "deploy": "vercel --prod",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@extractus/article-extractor": "^8.0.20",
    "@vercel/edge": "^1.1.1",
    "@vercel/kv": "^3.0.0",
    "@vercel/postgres": "^0.10.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "diff": "^8.0.3",
    "esbuild": "^0.25.0",
    "path-to-regexp": "^6.3.0",
    "pg": "^8.13.1",
    "puppeteer": "^24.39.1",
    "undici": "^6.22.1",
    "vite": "^7.3.1",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vercel/node": "^5.6.15",
    "bun-types": "^1.3.10",
    "typescript": "^5.3.0",
    "vercel": "^32.3.0",
    "vitest": "^4.0.17"
  },
  "overrides": {
    "diff": "^8.0.3",
    "path-to-regexp": "^6.3.0",
    "tar": "^7.5.3",
    "undici": "^6.22.1",
    "esbuild": "^0.25.0",
    "minimatch": "^3.1.4",
    "semver": "^7.5.2",
    "debug": "^4.3.1",
    "ajv": "^8.18.0",
    "@tootallnate/once": "^3.0.0"
  }
}
